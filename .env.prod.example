COMPOSE_PROJECT_NAME=vrp-infra

# Public routing
PLATFORM_PUBLIC_SCHEME=https
PLATFORM_PUBLIC_PORT_SUFFIX=
DOMAIN=example.com
PORTAL_HOST=portal.example.com
KEYCLOAK_HOST=auth.example.com
TRUCK_HOST=truck.example.com
SPBU_HOST=spbu.example.com
DISPATCH_HOST=dispatch.example.com
PLANNER_HOST=planner.example.com

# ACME / TLS
ACME_EMAIL=ops@example.com

# Keycloak
KEYCLOAK_PLATFORM=linux/amd64
KEYCLOAK_REALM=vrp-platform
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-strong-password
KEYCLOAK_DB_HOST=keycloak-db
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=replace-with-strong-password

# Bootstrap users
KEYCLOAK_SAMPLE_PASSWORD=disable-or-rotate-before-go-live
PORTAL_ADMIN_USERNAME=admin
PORTAL_ADMIN_PASSWORD=disable-or-rotate-before-go-live
PORTAL_ADMIN_EMAIL=admin@example.com
PORTAL_ADMIN_FIRST_NAME=Portal
PORTAL_ADMIN_LAST_NAME=Admin

# OAuth2 Proxy
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_CLIENT_SECRET=replace-with-strong-secret
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64-secret

# Truck Master Data
TRUCK_DB_PORT=5432
TRUCK_DB_NAME=truck_master_data
TRUCK_DB_USER=truck
TRUCK_DB_PASSWORD=replace-with-strong-password
TRUCK_SPBU_MASTERDATA_URL=http://spbu-backend:8000

# SPBU Master Data
SPBU_DB_PORT=5432
SPBU_DB_NAME=spbu_master_data
SPBU_DB_USER=spbu
SPBU_DB_PASSWORD=replace-with-strong-password

# VRP Planner
PLANNER_DB_PORT=5432
PLANNER_DB_NAME=vrp_planner
PLANNER_DB_USER=planner
PLANNER_DB_PASSWORD=replace-with-strong-password
