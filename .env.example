COMPOSE_PROJECT_NAME=vrp-infra

# Local domain mode
PLATFORM_USE_HOSTS_FILE=false
PLATFORM_LOCAL_DOMAIN=localhost
PLATFORM_BASE_DOMAIN=localhost
PLATFORM_PUBLIC_SCHEME=http
# Leave empty on port 80. Set a value like :8088 when TRAEFIK_HTTP_PORT is not 80.
PLATFORM_PUBLIC_PORT_SUFFIX=

# Traefik
TRAEFIK_BIND_HOST=127.0.0.1
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8081

# Host-based routing
PORTAL_HOST=portal.localhost
KEYCLOAK_HOST=auth.localhost
# Internal URL used by containers for Keycloak discovery. Keep this on Docker port 80 even if the host uses another published port.
KEYCLOAK_INTERNAL_URL=http://auth.localhost
TRUCK_HOST=truck.localhost
SPBU_HOST=spbu.localhost
PLANNER_HOST=planner.localhost

# Keycloak
KEYCLOAK_PLATFORM=linux/amd64
KEYCLOAK_REALM=vrp-platform
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-me
KEYCLOAK_DB_HOST=keycloak-db
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=replace-me
KEYCLOAK_SAMPLE_PASSWORD=replace-me
PORTAL_ADMIN_USERNAME=admin
PORTAL_ADMIN_PASSWORD=admin
PORTAL_ADMIN_EMAIL=admin@local.vrp
PORTAL_ADMIN_FIRST_NAME=Portal
PORTAL_ADMIN_LAST_NAME=Admin

# External database compatibility
DATABASE_URL=postgresql+psycopg2://keycloak:replace-me@keycloak-db:5432/keycloak
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=replace-me
POSTGRES_PORT=5432

# OAuth2 Proxy
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_CLIENT_SECRET=replace-me
# Generated by scripts/init-env.sh as a valid 32-byte base64 secret for oauth2-proxy cookies.
OAUTH2_PROXY_COOKIE_SECRET=replace-me

# Truck Master Data
TRUCK_DB_PORT=5432
TRUCK_DB_NAME=truck_master_data
TRUCK_DB_USER=truck
TRUCK_DB_PASSWORD=replace-me
TRUCK_SPBU_MASTERDATA_URL=http://spbu-backend:8000

# SPBU Master Data
SPBU_DB_PORT=5432
SPBU_DB_NAME=spbu_master_data
SPBU_DB_USER=spbu
SPBU_DB_PASSWORD=replace-me
SPBU_DATABASE_URL=postgresql+psycopg2://${SPBU_DB_USER}:${SPBU_DB_PASSWORD}@spbu-db:${SPBU_DB_PORT}/${SPBU_DB_NAME}

# VRP Planner
PLANNER_DB_PORT=5432
PLANNER_DB_NAME=vrp_planner
PLANNER_DB_USER=planner
PLANNER_DB_PASSWORD=replace-me
ROUTEFINDER_DEFAULT_ENABLED=false
ROUTEFINDER_CLUSTER_MODE=soft
ROUTEFINDER_MAX_CLUSTER_SIZE=5

# Future production placeholders
DOMAIN=example.com
ACME_EMAIL=ops@example.com
