COMPOSE_PROJECT_NAME=vrp-infra

# Local domain mode
PLATFORM_USE_HOSTS_FILE=false
PLATFORM_LOCAL_DOMAIN=localhost
PLATFORM_BASE_DOMAIN=localhost
PLATFORM_PUBLIC_SCHEME=http
PLATFORM_PUBLIC_PORT_SUFFIX=

# Traefik
TRAEFIK_BIND_HOST=127.0.0.1
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8081

# Host-based routing
PORTAL_HOST=portal.localhost
KEYCLOAK_HOST=auth.localhost
TRUCK_HOST=truck.localhost
SPBU_HOST=spbu.localhost
DISPATCH_HOST=dispatch.localhost

# Keycloak
KEYCLOAK_PLATFORM=linux/amd64
KEYCLOAK_REALM=vrp-platform
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-me
KEYCLOAK_DB_HOST=host.docker.internal
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=ferdeh_lab
KEYCLOAK_DB_USER=ferdeh
KEYCLOAK_DB_PASSWORD=replace-me
KEYCLOAK_SAMPLE_PASSWORD=replace-me

# External database compatibility
DATABASE_URL=postgresql+psycopg2://ferdeh:replace-me@host.docker.internal:5432/ferdeh_lab
POSTGRES_DB=ferdeh_lab
POSTGRES_USER=ferdeh
POSTGRES_PASSWORD=replace-me
POSTGRES_PORT=5432

# OAuth2 Proxy
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_CLIENT_SECRET=replace-me
OAUTH2_PROXY_COOKIE_SECRET=replace-me

# Future production placeholders
DOMAIN=example.com
ACME_EMAIL=ops@example.com
